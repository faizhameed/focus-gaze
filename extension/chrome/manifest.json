{
  "manifest_version": 3,
  "name": "focusGaze Bridge",
  "version": "0.6.0",
  "description": "Sends active tab URLs to the local focusGaze app for focus monitoring.",
  "key": "",
  "permissions": [
    "tabs",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "focusGaze Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "http://127.0.0.1/*",
      "http://localhost/*"
    ]
  }
}
